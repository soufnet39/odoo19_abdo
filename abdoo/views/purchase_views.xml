<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_hide_taxes" model="ir.ui.view">
        <field name="name">purchase.order.form.hide.taxes</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <!-- Hide taxes column in order lines list -->
            <!-- <field name="tax_ids" position="attributes">
                <attribute name="column_invisible">True</attribute>
                <attribute name="invisible">True</attribute>
            </field> -->
            <!-- Replace tax totals widget with just the total amount -->
            <field name="tax_totals" position="replace">
                <field name="amount_total" string="Total" widget="monetary" nolabel="0" readonly="1" class="oe_subtotal_footer_separator fw-bolder"/>
            </field>
        </field>
    </record>

    <record id="sale_order_form_hide_taxes" model="ir.ui.view">
        <field name="name">sale.order.form.hide.taxes</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Hide taxes column in order lines list -->
            <xpath expr="//list//field[@name='tax_ids']" position="attributes">
                <attribute name="column_invisible">True</attribute>
                <attribute name="optional">hide</attribute>
            </xpath>
            <!-- Hide the discount/buttons bar below order lines -->
            <xpath expr="//div[@name='so_button_below_order_lines']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <!-- Replace tax totals widget with a clean Total label + amount line -->
            <field name="tax_totals" position="replace">
                <div class="d-flex align-items-center">
                    <span style="padding-right: 20px;">Total:</span>
                    <field name="amount_total" widget="monetary" nolabel="1" readonly="1" class="fw-bolder"/>
                </div>
            </field>
        </field>
    </record>
</odoo>
