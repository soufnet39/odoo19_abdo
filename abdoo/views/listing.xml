<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Report action — bound to the product.template Print menu
         ============================================================ -->
    <record id="action_report_product_listing" model="ir.actions.report">
        <field name="name">Listing Produits</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">abdoo.report_product_listing_document</field>
        <field name="report_file">abdoo.report_product_listing_document</field>
        <field name="print_report_name">'Listing Produits'</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_type">report</field>
    </record>

    <!-- ============================================================
         QWeb template — PDF body
         ============================================================ -->
    <template id="report_product_listing_document">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <div class="page">
                    <h2 class="mb-4">Listing des Produits</h2>
                    <table class="table table-sm table-bordered o_main_table" style="font-size:0.75em;">
                        <thead style="background-color:#f5f5f5;">
                            <tr>
                                <th class="text-center" style="width:40px">#</th>
                                <th>Désignation</th>
                                <th>Réf. Originale</th>

                                <th>Réf. Filtre</th>
                                <th>Marq. Filtre</th>
                                <th class="text-end">Prix</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="product">
                                <tr>
                                    <td class="text-center" t-out="product_index + 1"/>

                                    <td t-out="product.display_name or ''"/>
                                    <td t-out="product.default_code or ''"/>
                                    <td t-out="product.reference_filter or ''"/>
                                    <td t-out="product.filter_marque.name or ''"/>
                                    <td class="text-end">
                                        <span t-field="product.list_price" t-options='{"widget": "monetary", "display_currency": product.currency_id}'/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <p class="text-muted mt-4" style="font-size:0.8em;">
                        <t t-out="len(docs)"/>
 produit(s) imprimé(s)
                    </p>
                </div>
            </t>
        </t>
    </template>

</odoo>
