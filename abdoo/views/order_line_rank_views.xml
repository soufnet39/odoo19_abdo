<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sale Order: add rank column to order lines -->
    <record id="view_sale_order_form_rank" model="ir.ui.view">
        <field name="name">sale.order.form.rank</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="before">
                <field name="line_number" string="#" readonly="1" width="40"/>
            </xpath>
        </field>
    </record>

    <!-- Purchase Order: add rank column to order lines -->
    <record id="view_purchase_order_form_rank" model="ir.ui.view">
        <field name="name">purchase.order.form.rank</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="before">
                <field name="line_number" string="#" readonly="1" width="40"/>
            </xpath>
        </field>
    </record>

</odoo>
