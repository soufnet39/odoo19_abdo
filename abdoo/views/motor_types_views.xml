<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="motor_types_view_tree" model="ir.ui.view">
        <field name="name">motor.types.view.tree</field>
        <field name="model">motor.types</field>
        <field name="arch" type="xml">
            <list string="Types Moteur">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="motor_types_view_form" model="ir.ui.view">
        <field name="name">motor.types.view.form</field>
        <field name="model">motor.types</field>
        <field name="arch" type="xml">
            <form string="Type Moteur">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_motor_types" model="ir.actions.act_window">
        <field name="name">Types Moteur</field>
        <field name="res_model">motor.types</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
