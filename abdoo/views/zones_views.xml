<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="zones_view_list" model="ir.ui.view">
        <field name="name">zones.view.list</field>
        <field name="model">zones</field>
        <field name="arch" type="xml">
            <list string="Zones">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="zones_view_form" model="ir.ui.view">
        <field name="name">zones.view.form</field>
        <field name="model">zones</field>
        <field name="arch" type="xml">
            <form string="Zone">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_zones" model="ir.actions.act_window">
        <field name="name">Zones</field>
        <field name="res_model">zones</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
