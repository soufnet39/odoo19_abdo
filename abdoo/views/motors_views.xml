<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="motors_view_tree" model="ir.ui.view">
        <field name="name">motors.view.tree</field>
        <field name="model">motors</field>
        <field name="arch" type="xml">
            <list string="Moteurs">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="motors_view_form" model="ir.ui.view">
        <field name="name">motors.view.form</field>
        <field name="model">motors</field>
        <field name="arch" type="xml">
            <form string="Moteur">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_motors" model="ir.actions.act_window">
        <field name="name">Moteurs</field>
        <field name="res_model">motors</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
