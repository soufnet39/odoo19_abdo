<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- New Report Action for Abdoo Sale Order -->
    <record id="action_report_sale_order_abdoo" model="ir.actions.report">
        <field name="name">Etiquette</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">abdoo.report_saleorder_abdoo</field>
        <field name="report_file">abdoo.report_saleorder_abdoo</field>
        <field name="print_report_name">(object.state in ('draft', 'sent') and 'Devis - %s' % (object.name)) or 'Commande - %s' % (object.name)</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Main report template -->
    <template id="report_saleorder_abdoo">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="abdoo.report_saleorder_abdoo_document" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>

    <!-- Document template with special Abdoo format for small printers (10cm width) -->
    <template id="report_saleorder_abdoo_document">
        <t t-call="web.basic_layout">
            <div class="page" style="font-family: monospace; font-size: 11px; width: 100%; max-width: 10cm; margin: 0 auto;">
                <!-- Title -->
                <div style="text-align:center">
                   <span style="font-size: 22px; font-weight: bold;">GRAND SOUFFLE</span><br/>
                   <span>Vente de tous types de filtres pour voitures et camions</span> <br/>
                   <span>05.49.26.10.37</span> 
                </div>
                <div style="text-align: center; margin-bottom: 8px;">
                    <strong style="font-size: 14px; border: 1px solid #000; padding: 3px 8px; display: inline-block;">BON DE COMMANDE</strong>
                </div>

                <!-- Order Info -->
                <div style="margin-bottom: 8px;">
                    <div>B.C.N°: <span t-field="doc.name"/></div>
                    <div>Date: <span t-field="doc.date_order" t-options='{"widget": "date"}'/></div>
                    <!-- <div>Vendeur: <span t-field="doc.user_id"/></div> -->
                    <div t-if="doc.client_order_ref">Réf.Client: <span t-field="doc.client_order_ref"/></div>
                </div> <br/>

                <!-- Separator -->
                <div style="border-top: 1px dashed #000; margin: 6px 0;"></div>

                <!-- Client -->
                <div style="margin-bottom: 8px; text-align: right;">
                    <strong>Client:</strong> <span t-field="doc.partner_id.name"/><br/>
                    <span t-if="doc.partner_id.street" t-field="doc.partner_id.street"/><br/>
                    <span t-if="doc.partner_id.city" t-field="doc.partner_id.city"/>
                    <span t-if="doc.partner_id.zip"> - <span t-field="doc.partner_id.zip"/></span><br/>
                    <span t-if="doc.partner_id.phone">Tél: <span t-field="doc.partner_id.phone"/></span>
                </div>

                <!-- Separator -->
                <div style="border-top: 1px dashed #000; margin: 6px 0;"></div>

                <!-- Order Lines (no table, compact blocks) -->
                <div t-foreach="doc.order_line" t-as="line" style="margin-bottom: 6px;">
                    <div>
                        <strong><span t-out="line.line_number"/></strong> - <span t-field="line.name"/>
                    </div>
                    <div>
                        <span>
                            Réf:
                            <t t-set="code_parts" t-value="(line.product_id.default_code or '').split(',')"/>
                            <t t-foreach="code_parts" t-as="code_part">
                                <t t-if="not code_part_first">, </t>
                                <t t-out="code_part.replace(' ', '')"/>
                            </t>
                        </span>, 
                        <span t-if="line.product_id.filter_marque">
                            Marque: <span t-field="line.product_id.filter_marque"/>
                        </span>
                    </div>
                    <div style="text-align: right; margin-top: 2px;">
                        <span>Qte: <span t-field="line.product_uom_qty" t-options='{"widget": "integer"}'/></span>, 
                        <span>PU: <span t-field="line.price_unit"/></span>, 
                        <span>Prix: <strong><span t-field="line.price_subtotal"/></strong></span>
                    </div>
                    <div style="border-top: 1px dotted #aaa; margin-top: 4px;"></div>
                </div>

                <!-- Totals -->
                <div style="text-align: right; margin-top: 10px; font-size: 13px;">
                    <strong>TOTAL:</strong>
                    <strong><span t-field="doc.amount_total"/></strong>
                </div>

                <!-- Separator -->
                <div style="border-top: 1px dashed #000; margin: 10px 0;"></div>

                <!-- Signature area -->
                <!-- <div style="display: flex; justify-content: space-between; margin-top: 20px; text-align: center;">
                    <div style="width: 45%;">
                        <div style="border-top: 1px solid #000; padding-top: 3px;">Signature Client</div>
                    </div>
                    <div style="width: 45%;">
                        <div style="border-top: 1px solid #000; padding-top: 3px;">Signature Vendeur</div>
                    </div>
                </div> -->

                <!-- Footer -->
                <div style="text-align: center; margin-top: 15px; font-size: 9px; color: #555;">
                    <span t-field="doc.company_id.name"/> - Merci pour votre confiance
                </div>
            </div>
        </t>
    </template>

</odoo>
